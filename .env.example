# ===========================================
# OpenJam Docker Deployment Configuration
# ===========================================
# Copy this file to .env before running docker compose
# cp .env.example .env

# Session secret - CHANGE THIS before deploying!
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-this-in-production-use-random-string

# CORS origins - your frontend domain(s)
CORS_ORIGINS=http://localhost:8080

# MinIO credentials - change for production
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
